{
  "name": "xpress-ecg-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "node scripts/start-expo.cjs",
    "start:usb": "node scripts/start-expo-usb.cjs",
    "start:usb:devclient": "node scripts/start-expo-usb.cjs --dev-client",
    "start:devclient": "expo start --dev-client --port 19000 --localhost",
    "start:localhost": "expo start --port 19000 --localhost",
    "start:lan": "expo start --port 19000 --lan",
    "start:tunnel": "node scripts/start-expo.cjs start --tunnel --port 19000",
    "android": "expo start --android --port 19000 --lan",
    "ios": "expo start --ios --port 19000 --lan",
    "web": "expo start --web --port 19000",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/patch-expo-tunnel-timeout.cjs",
    "assets:placeholders": "node scripts/generate-placeholder-assets.cjs",
    "expo:connect": "node scripts/print-expo-connect.cjs",
    "net:diag": "node scripts/detect-hotspot-ip.cjs",
    "expo:diag": "node scripts/diag-expo-connect.cjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "ajv": "^8.17.1",
    "date-fns": "^3.6.0",
    "expo": "~54.0.0",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "graphql": "^16.13.2",
    "nativewind": "^4.0.1",
    "pngjs": "3.4.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/ngrok": "^4.1.3",
    "@types/node": "^25.5.2",
    "@types/react": "~19.1.10",
    "@types/react-native": "~0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "typescript": "~5.9.2"
  }
}
